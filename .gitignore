# Byte-compiled / cache
__pycache__/
*.pyc
*.pyo
.tmp/

# Data (released by organizers; not ours to redistribute in full)
/train/
/public_test/
/features/
/*.zip
*.jpeg:Zone.Identifier
*.jpg:Zone.Identifier

# Original user planning notes (kept locally, not part of the public repro package)
/prompt.txt

# Large CSVs (regenerable, not source)
/train_labels.csv
/sample_submission.csv
/submissions/*.csv

# Training checkpoints (only the frozen champion checkpoint under models/ is tracked, via Git LFS)
/checkpoints/

# Logs
/logs/

# Notebooks checkpoints
/notebooks/.ipynb_checkpoints/

# OS / editor
.DS_Store
.vscode/
*.swp

# Credentials / API tokens — never commit these
*token*.txt
token.txt
api_token_cli_submission.txt

# LaTeX build artifacts (report/freuid_technical_report.pdf itself is committed)
report/*.aux
report/*.bbl
report/*.blg
report/*.fdb_latexmk
report/*.fls
report/*.log
report/*.out
